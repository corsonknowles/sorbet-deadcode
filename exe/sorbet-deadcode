#!/usr/bin/env ruby
# frozen_string_literal: true

require "sorbet_deadcode"
require "optparse"

# Absolute path of the enclosing git repository, or nil when not in a checkout.
def git_toplevel
  root = IO.popen(["git", "rev-parse", "--show-toplevel"], err: File::NULL, &:read).strip
  $?.success? && !root.empty? ? root : nil
rescue StandardError
  nil
end

# Parse a --max-age value ("30d", "2w", "1m", "90") to seconds, or nil to disable.
def parse_max_age(value)
  text = value.to_s.strip.downcase
  return nil if %w[0 all none off].include?(text)

  m = text.match(/\A(\d+)\s*([dwm])?\z/)
  return nil unless m

  m[1].to_i * { "d" => 1, "w" => 7, "m" => 30 }.fetch(m[2] || "d") * 86_400
end

options = {
  paths: [],
  exclude_paths: ["/spec/", "/test/"],
  include_specs: false,
  lsp: false,
  hybrid: false,
  file_table: false,
  verify: true,
  parallel: 10,
  project_root: nil,
  isolated: false,
  reference_root: nil,
  output_index: nil,
  load_index: nil,
  intersect_index: nil,
  filter_paths: [],
  show_confidence: false,
  classify: false,
  only_action: nil,
  recent_within: 30 * 86_400,
  plain: false,
  report_dynamic_dispatch: false,
  report_non_ruby: false,
  spoom: false,
  remove: nil,
  apply: false,
}

OptionParser.new do |opts|
  opts.banner = "Usage: sorbet-deadcode [options] PATH..."

  opts.on("-x", "--exclude PATTERN", "Exclude paths containing PATTERN") do |pattern|
    options[:exclude_paths] << pattern
  end

  opts.on("--include-specs", "Include spec/ and test/ directories in analysis") do
    options[:include_specs] = true
  end

  opts.on("--lsp", "Use Sorbet LSP for type-aware analysis (requires sorbet setup)") do
    options[:lsp] = true
  end

  opts.on("--hybrid", "Prism-first pass, LSP validation of candidates only (recommended)") do
    options[:hybrid] = true
  end

  opts.on("--file-table", "Use Sorbet file-table dump (fastest, single pass)") do
    options[:file_table] = true
  end

  opts.on("--no-verify", "Skip ripgrep verification pass (faster but more false positives)") do
    options[:verify] = false
  end

  opts.on("--parallel N", Integer, "Number of concurrent LSP queries (default: 10, use with --lsp or --hybrid)") do |n|
    options[:parallel] = n
  end

  opts.on("--project-root DIR",
    "Root for ripgrep verification and non-Ruby refiners (default: the git toplevel,",
    "so references are checked repo-wide regardless of the current directory).") do |dir|
    options[:project_root] = dir
  end

  opts.on("--isolated",
    "Don't auto-detect the git root; scope verification/refiners to the current",
    "directory instead. Use for non-git trees or to deliberately limit scope.") do
    options[:isolated] = true
  end

  opts.on("--no-routes", "Disable automatic config/routes.rb scanning for controller action references.") do
    options[:no_routes] = true
  end

  opts.on("--no-yaml", "Disable framework-YAML scanning (config keys mapping to Ruby methods).") do
    options[:no_yaml] = true
  end

  opts.on("--no-erb", "Disable ERB template scanning for method/constant references.") do
    options[:no_erb] = true
  end

  opts.on("--no-rabl", "Disable RABL template scanning for method/constant references.") do
    options[:no_rabl] = true
  end

  opts.on("--no-graphql", "Disable standalone GraphQL SDL (.graphql) scanning for resolver method references.") do
    options[:no_graphql] = true
  end

  opts.on("--index OUTPUT_FILE",
    "Run analysis and save the full dead-code index to a JSON file for later use.",
    "Combine with --report to load-and-filter instead of re-analyzing.") do |f|
    options[:output_index] = f
  end

  opts.on("--report INDEX_FILE",
    "Load a pre-built index and report dead code without re-analyzing.",
    "Combine with --paths to filter the report to specific directories.") do |f|
    options[:load_index] = f
  end

  opts.on("--intersect OTHER_INDEX",
    "Only report definitions that appear in BOTH this run AND OTHER_INDEX.",
    "Use to cross-compare sorbet-deadcode results with Spoom or another run.") do |f|
    options[:intersect_index] = f
  end

  opts.on("--spoom",
    "Cross-check against spoom: keep only candidates spoom also reports dead.",
    "Runs spoom's dead-code analysis on the same paths via its API (requires the spoom gem).") do
    options[:spoom] = true
  end

  opts.on("--confidence", "Show confidence tier (high/medium/low) for each candidate.") do
    options[:show_confidence] = true
  end

  opts.on("--classify",
    "Annotate each candidate with confidence, reference count, risk flags, and a",
    "suggested action (safe_delete / delete_with_spec / review / keep). Requires rg.") do
    options[:classify] = true
  end

  opts.on("--only ACTION",
    "Only show candidates whose suggested action is ACTION",
    "(safe_delete, delete_with_spec, review, keep).") do |action|
    options[:only_action] = action.to_sym
  end

  opts.on("--remove TIER",
    "Remove dead code in the given action TIER (safe_delete, delete_with_spec,",
    "review, or all) by leveraging spoom's syntax-aware remover (requires the spoom",
    "gem). Dry run by default — prints a unified diff; pass --apply to write. Pair with",
    "--spoom to only remove candidates both tools agree are dead.") do |tier|
    options[:remove] = tier.to_sym
  end

  opts.on("--apply", "With --remove, actually write the edits instead of printing a dry-run diff.") do
    options[:apply] = true
  end

  opts.on("--max-age AGE",
    "Treat definitions introduced within AGE (e.g. 30d, 2w, 1m; default 30d) as",
    "recently-added: flag them and route to review instead of safe_delete. Uses git",
    "line history. Pass 0/all to disable.") do |value|
    options[:recent_within] = parse_max_age(value)
  end

  opts.on("--plain",
    "Print a flat list of candidates instead of the default confidence/action",
    "tiered view. Combine with --no-verify for a quick, ripgrep-free scan.") do
    options[:plain] = true
  end

  opts.on("--report-dynamic-dispatch",
    "Report methods that are only kept alive by a variable-target send/public_send",
    "in their namespace, instead of conservatively keeping them. They surface as",
    "low-confidence candidates — pair with --classify or --confidence to review.") do
    options[:report_dynamic_dispatch] = true
  end

  opts.on("--report-non-ruby",
    "Report methods/classes kept alive only by a non-Ruby reference (route / YAML /",
    "ERB / RABL / GraphQL SDL) instead of excluding them. They surface as low-confidence",
    "candidates tagged with the source (e.g. flags=kept_by:graphql_sdl).") do
    options[:report_non_ruby] = true
  end

  opts.on("--reference-root DIR",
    "Also scan DIR for references (not definitions). Prevents public API",
    "methods from appearing dead when callers live outside --paths.") do |dir|
    options[:reference_root] = dir
  end

  opts.on("-h", "--help", "Show this help") do
    puts opts
    exit
  end

  opts.on("-v", "--version", "Show version") do
    puts SorbetDeadcode::VERSION
    exit
  end
end.parse!

options[:paths] = ARGV.empty? ? ["."] : ARGV
options[:filter_paths] = options[:paths] if options[:load_index]
options[:exclude_paths] = [] if options[:include_specs]

# Default the project root to the git toplevel so ripgrep verification and the non-Ruby
# refiners operate repo-wide even when run from inside a pack/subdirectory. Without this,
# project_root defaults to the cwd, scoping verification to that subtree and reporting
# cross-pack-referenced methods as dead (a false-positive source). --isolated or an
# explicit --project-root opts out.
if options[:project_root].nil?
  options[:project_root] = options[:isolated] ? "." : (git_toplevel || ".")
end

mode_count = [options[:lsp], options[:hybrid], options[:file_table]].count(true)
if mode_count > 1
  $stderr.puts "Error: Only one of --lsp, --hybrid, or --file-table may be specified."
  exit 1
end

# --reference-root is only consumed by the default Prism analyze path; the LSP/hybrid/
# file-table finders don't accept it yet. Warn instead of silently ignoring it.
if options[:reference_root] && mode_count.positive?
  $stderr.puts "[sorbet-deadcode] --reference-root is only applied in the default mode; " \
               "ignoring it for --lsp/--hybrid/--file-table."
end

# --report loads a pre-built (already-verified) index instead of re-analyzing. When
# set, we skip analysis, verification, and re-indexing, but still flow into the shared
# classify / confidence / render pipeline below so a cached index can be classified.
from_index = !options[:load_index].nil?

# Like --reference-root, dynamic-dispatch reporting is implemented only on the default
# Prism analyze path; the LSP/hybrid/file-table finders and cached --report indexes
# don't honor it. Warn instead of silently ignoring it.
if options[:report_dynamic_dispatch] && (mode_count.positive? || from_index)
  $stderr.puts "[sorbet-deadcode] --report-dynamic-dispatch only applies in the default mode; " \
               "ignoring it for --lsp/--hybrid/--file-table/--report."
end

results = if from_index
  index = SorbetDeadcode::Index.load(options[:load_index])
  index = index.filter_paths(options[:filter_paths]) unless options[:filter_paths].empty?
  index = index.intersect(SorbetDeadcode::Index.load(options[:intersect_index])) if options[:intersect_index]
  $stderr.puts "Loaded #{index.dead_definitions.size} dead code candidates from #{options[:load_index]}."
  index.dead_definitions
elsif options[:hybrid]
  SorbetDeadcode.analyze_hybrid(
    project_root: options[:project_root],
    paths: options[:paths],
    exclude_paths: options[:exclude_paths],
    parallel: options[:parallel],
  )
elsif options[:file_table]
  SorbetDeadcode.analyze_file_table(
    project_root: options[:project_root],
    paths: options[:paths],
    exclude_paths: options[:exclude_paths],
  )
elsif options[:lsp]
  SorbetDeadcode.analyze_with_lsp(
    project_root: options[:project_root],
    paths: options[:paths],
    exclude_paths: options[:exclude_paths],
    parallel: options[:parallel],
  )
else
  SorbetDeadcode.analyze(
    options[:paths],
    exclude_paths: options[:exclude_paths],
    reference_paths: options[:reference_root],
    dynamic_dispatch: options[:report_dynamic_dispatch] ? :report : :exclude,
  )
end

# Apply the non-Ruby reference refiners to EVERY analysis mode's results, not just the
# default Prism path. Without this, routed controllers and template-/config-referenced
# methods resurface as false positives under --lsp/--hybrid/--file-table. (--report
# results were already refined when the index was built, so skip them here.)
unless from_index
  refiner_mode = options[:report_non_ruby] ? :report : :exclude
  refiners = []
  refiners << SorbetDeadcode::Refiners::RouteRefiner.new(options[:project_root], mode: refiner_mode) unless options[:no_routes]
  refiners << SorbetDeadcode::Refiners::YamlRefiner.new(options[:project_root], mode: refiner_mode) unless options[:no_yaml]
  refiners << SorbetDeadcode::Refiners::ErbRefiner.new(options[:project_root], mode: refiner_mode) unless options[:no_erb]
  refiners << SorbetDeadcode::Refiners::RablRefiner.new(options[:project_root], mode: refiner_mode) unless options[:no_rabl]
  refiners << SorbetDeadcode::Refiners::GraphqlRefiner.new(options[:project_root], mode: refiner_mode) unless options[:no_graphql]
  results = refiners.reduce(results) { |candidates, refiner| refiner.refine(candidates) }
end

# --remove operates on classified action tiers, which need ripgrep verification.
if options[:remove] && !options[:verify]
  $stderr.puts "Error: --remove needs classification; it can't be combined with --no-verify."
  exit 1
end

# Default to the classified, confidence/action-tiered view. --plain prints a flat list,
# and --no-verify (no ripgrep) implies --plain since classification needs ripgrep.
# --remove always classifies (it selects candidates by suggested action tier).
do_classify = (options[:classify] || options[:only_action] || options[:remove] || !options[:plain]) && options[:verify]

# The standalone verify pass produces the canonical verified-dead set consumed by --index,
# --intersect, and the plain list. Skip it for the default classify view: the classifier
# does its own ripgrep over the pre-verify candidates and yields richer tiers (spec-only /
# non-Ruby / inline-constant / keep) that verify would otherwise have silently dropped.
needs_verified_set = options[:plain] || options[:output_index] || options[:intersect_index]

if !from_index && options[:verify] && needs_verified_set && !results.empty?
  verifier = SorbetDeadcode::Verifier::RipgrepVerifier.new(
    project_root: options[:project_root],
    exclude_paths: options[:exclude_paths],
  )
  results = verifier.verify(results)
end

# --index: save the result to a JSON file for later --report / --intersect use
if !from_index && options[:output_index]
  index = SorbetDeadcode::Index.new(
    dead_definitions: results,
    paths: options[:paths],
    exclude_paths: options[:exclude_paths],
  )
  index.write(options[:output_index])
  $stderr.puts "Index written to #{options[:output_index]} (#{results.size} candidates)."
end

# --intersect: filter to definitions that also appear in another index.
# (In --report mode the intersection was already applied while loading the index.)
if !from_index && options[:intersect_index]
  other = SorbetDeadcode::Index.load(options[:intersect_index])
  results = SorbetDeadcode::Index.new(dead_definitions: results, paths: options[:paths])
              .intersect(other)
              .dead_definitions
  $stderr.puts "Intersection: #{results.size} candidates appear in both indexes."
end

# --spoom: run spoom's dead-code analysis on the same paths (via its Ruby API) and keep only
# the candidates both tools agree are dead — the highest-confidence set, with no intermediate file.
if !from_index && options[:spoom]
  spoom_index = SorbetDeadcode::Spoom::Runner.dead_index(
    options[:paths], project_root: options[:project_root], exclude_paths: options[:exclude_paths],
  )
  results = SorbetDeadcode::Index.new(dead_definitions: results, paths: options[:paths])
              .intersect(spoom_index)
              .dead_definitions
  $stderr.puts "Spoom intersection: #{results.size} candidates also reported dead by spoom."
end

if results.empty?
  $stderr.puts "No dead code found."
  exit 0
end

# Default view: annotate each candidate with confidence, refs, flags, and a suggested
# action. Live candidates (:keep) are hidden unless explicitly requested via --only keep.
if do_classify
  classifier = SorbetDeadcode::Classifier.new(
    project_root: options[:project_root],
    exclude_paths: options[:exclude_paths],
    recent_within: options[:recent_within],
  )
  classified = classifier.classify(results)

  # --remove: hand the selected action tier to spoom's syntax-aware remover. `all` removes every
  # actionable tier (everything except :keep); otherwise only the named tier (e.g. safe_delete).
  if options[:remove]
    tier = options[:remove]
    targets = if tier == :all
      classified.reject { |c| c.suggested_action == :keep }
    else
      classified.select { |c| c.suggested_action == tier }
    end

    if targets.empty?
      $stderr.puts "No candidates in tier '#{tier}' to remove."
      exit 0
    end

    mode = options[:apply] ? "Removing" : "Dry run (pass --apply to write):"
    $stderr.puts "#{mode} #{targets.size} candidate(s) in tier '#{tier}' via spoom's remover.\n\n"

    outcomes = SorbetDeadcode::Spoom::Remover.remove(
      targets.map(&:definition),
      project_root: options[:project_root],
      apply: options[:apply],
    )

    outcomes.each do |outcome|
      defn = outcome.definition
      case outcome.status
      when :would_remove
        puts "# #{defn.kind} #{defn.full_name} (#{defn.location})"
        puts outcome.detail
        puts
      when :removed
        puts "  [removed] #{defn.kind} #{defn.full_name} -> #{outcome.detail}"
      when :skipped
        puts "  [skipped] #{defn.kind} #{defn.full_name}: #{outcome.detail}"
      when :failed
        puts "  [failed]  #{defn.kind} #{defn.full_name}: #{outcome.detail}"
      end
    end

    counts = outcomes.group_by(&:status).transform_values(&:size)
    $stderr.puts "\n#{counts.map { |status, n| "#{n} #{status}" }.join(', ')}."
    $stderr.puts "Re-run with --apply to write these edits." unless options[:apply]
    exit 0
  end

  classified = if options[:only_action]
    classified.select { |c| c.suggested_action == options[:only_action] }
  else
    classified.reject { |c| c.suggested_action == :keep }
  end

  if classified.empty?
    $stderr.puts "No dead code found."
    exit 0
  end

  $stderr.puts "Classified #{classified.size} candidates:\n\n"
  classified.sort_by { |c| [c.suggested_action.to_s, c.definition.full_name] }.each do |c|
    flags = c.flags.empty? ? "" : " flags=#{c.flags.join(',')}"
    puts "  [#{c.suggested_action}] [#{c.confidence}] #{c.definition.kind} #{c.definition.full_name} " \
         "(refs=#{c.external_reference_count}#{flags})"
    puts "    #{c.definition.location}"
  end
  puts "\n#{classified.size} candidates classified."
  exit 1
end

$stderr.puts "Found #{results.size} dead code candidates:\n\n"

# Build ref index for confidence scoring if requested
ref_index = if options[:show_confidence]
  require "sorbet_deadcode/analyzer/dead_code_analyzer"
  # Approximate from the existing results — build a minimal ref_index
  { typed_by_name: {}, untyped_methods: Set.new, constants: Set.new,
    method_prefixes: Set.new, method_suffixes: Set.new, dynamic_namespaces: Set.new }
end

results.sort_by(&:full_name).each do |defn|
  if options[:show_confidence] && ref_index
    confidence = SorbetDeadcode::Analyzer::Confidence.for(defn, ref_index)
    puts "  [#{confidence}] #{defn.kind} #{defn.full_name}"
  else
    puts "  #{defn.kind} #{defn.full_name}"
  end
  puts "    #{defn.location}"
end

puts "\n#{results.size} dead code candidates found."
exit 1
